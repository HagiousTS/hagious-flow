# Hagious Flow · variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local — ele já está no .gitignore.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Opcional: tracking de erros via Sentry. Sem DSN, init é no-op e
# nenhum dado sai do browser.
# VITE_SENTRY_DSN=https://xxxx@oNNNNNN.ingest.sentry.io/PPPPPP
# VITE_RELEASE=v0.4.0
